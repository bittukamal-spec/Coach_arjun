// Arjun — AI Mental Coach Database Schema
// Run `npm run db:migrate` to apply changes
// Run `npm run db:studio` to open a visual database browser

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  googleId  String?  @unique  // kept optional for potential future re-addition
  email     String   @unique
  name      String
  password  String?            // bcrypt hash — null for any legacy Google accounts
  avatar    String?

  // "free" = 14-day trial, then blocked
  // "premium" = full access (₹299/month)
  tier         String    @default("free")
  trialStarted DateTime?  // set on registration; 14-day trial window

  // "en" = English, "hi" = Hindi
  language  String   @default("en")

  // Onboarding — collected after first login
  sport           String?          // e.g. "cricket", "badminton"
  experienceLevel String?          // "beginner" | "amateur" | "competitive" | "professional"
  goals           String  @default("[]") // JSON array e.g. '["focus","confidence"]'
  onboardingDone  Boolean @default(false)

  // Extended onboarding fields
  competitionLevel  String?   // "recreational" | "local" | "state" | "national" | "international"
  primaryChallenge  String?   // "nerves" | "failure" | "focus" | "family_pressure" | "injury" | "consistency"
  pressureResponse  String?   // "has_routine" | "talks_to_others" | "ignores_it" | "struggles" | "unaware"
  position          String?   // free text, e.g. "batsman", "goalkeeper"

  // Pre-match ritual
  ritualName    String?
  ritualSteps   String  @default("[]") // JSON: [{type, label}]

  // WhatsApp / notifications (Sprint 2)
  phone         String?           // "+917012345678"
  reminderOptIn Boolean  @default(false)

  // Razorpay subscription
  razorpaySubscriptionId  String?
  razorpayCustomerId      String?
  subscriptionPlanType    String?   // "monthly" | "yearly"
  subscriptionStartDate   DateTime?
  subscriptionEndDate     DateTime?

  // Gamification
  xp                  Int       @default(0)
  streakFreezeCount   Int       @default(1)
  lastFreezeUsedAt    DateTime?

  // OCEAN Big Five personality (1–5 scale, null = not taken yet)
  oceanO        Int?   // Openness
  oceanC        Int?   // Conscientiousness
  oceanE        Int?   // Extraversion
  oceanA        Int?   // Agreeableness
  oceanN        Int?   // Neuroticism

  // Mental Game Profile intro (AI-generated, cached after onboarding)
  profileIntro  String?

  // Before You Play — saved cue word
  cueWord         String?
  cueLanguage     String?
  cueArousalState String?   // "calm_down" | "lock_in" | "fire_up"
  cueEventType    String?   // "before_match"
  cueUpdatedAt    DateTime?

  // Demographics
  age           Int?   // age in years

  // Minor-user compliance (DPDP) — set at registration
  dateOfBirth           DateTime? // null for accounts created before the age gate
  guardianEmail         String?   // required at signup when under 18
  guardianConsentAt     DateTime? // set when guardian confirms via emailed link
  guardianConsentToken  String?   @unique // one-time consent-link token

  messages               Message[]
  safetyEvents           SafetyEvent[]
  checkIns               CheckIn[]
  memories               UserMemory[]
  passwordResets         PasswordResetToken[]
  achievements           UserAchievement[]
  drillCompletions       DrillCompletion[]
  debriefs               Debrief[]
  gameSessions           GameSession[]
  chatSessions           ChatSession[]
  mentalFitnessEntries   MentalFitnessEntry[]
  toolReports            ToolReport[]
  weeklyReports          WeeklyReport[]
  selfTalkCards          SelfTalkCard[]
  bodyResetSessions      BodyResetSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CheckIn {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood        Int      // 1–5
  focus       Int      // 1–5
  confidence  Int      // 1–5
  energy      Int?     // 1–5: how physically/mentally energised the athlete feels
  sleep       String?  // "poor" | "ok" | "great"
  reflection  String?  // optional free-text, max 500 chars
  gratitude   String?  // optional: one win from today, max 300 chars
  type        String   @default("checkin")   // "checkin" | "freeze"
  createdAt   DateTime @default(now())
}

model Message {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          String       // "user" | "assistant"
  content       String
  sessionType   String?      // "match_prep" | "post_match" | "build_focus" | "confidence" | "handle_pressure" | "open" | "post_checkin"
  chatSessionId String?
  chatSession   ChatSession? @relation(fields: [chatSessionId], references: [id])
  createdAt     DateTime     @default(now())
}

model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memKey    String   // e.g., "fear", "strength", "background", "pattern", "trigger"
  value     String   // e.g., "freezes before penalty kicks"
  source    String   @default("chat") // "chat" | "onboarding"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, memKey])
}

model UserAchievement {
  id       String   @id @default(cuid())
  userId   String
  key      String   // e.g. "first_checkin", "streak_7"
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model DrillCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  drillIndex  Int
  completedAt DateTime @default(now())
}

model Debrief {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  wentWell       String   // max 500 chars (legacy text; new flow populates from chips)
  doDifferently  String   // max 500 chars (legacy text; new flow populates from wouldChange chip)
  nextFocus      String   // max 300 chars (chip label or free text)
  arjunInsight   String?  // AI-generated coaching insight
  // ── Structured fields added for quick/full mode rebuild ───────────────────
  mode            String?  // "quick" | "full"
  eventType       String?  // "Match" | "Tournament" | "Trial / Selection" | etc.
  resultType      String?  // one of the result chip labels
  wentWellChips   String?  // JSON array of chip labels e.g. '["Effort","Focus"]'
  wentWellText    String?  // optional typed text (full mode only, max 80 chars)
  wouldChange     String?  // single chip label from Screen 3
  wouldChangeText String?  // optional typed text (full mode only, max 80 chars)
  cueWordFeedback String?  // "helped" | "forgot" | "no_help"
  sport           String?  // snapshot of user.sport at time of debrief
  xpAwarded       Int?     // 15 quick / 20 full (legacy entries = 10)
  createdAt      DateTime @default(now())
}

model GameSession {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameType    String   // "grid" | "stroop" | "reaction" | "thought" | "filter"
  score       Int
  completedAt DateTime @default(now())
}

model ChatSession {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionType String    @default("general")
  mode        String    @default("main") // "main" | "quick"
  title       String?
  summary     String?
  status      String    @default("active") // "active" | "ended"
  createdAt   DateTime  @default(now())
  endedAt     DateTime?
  messages    Message[]

  @@index([userId, mode])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MentalFitnessEntry {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           String   // "YYYY-MM-DD" IST — avoids UTC midnight bug
  mood           Int?     // 1–5 (mood card, optional for back-compat)
  focus          Int      // 1–5
  confidence     Int      // 1–5
  drive          Int      // 1–5
  calm           Int      // 1–5
  selftalk       Int      // 1–5
  bounce         Int      // 1–5
  arjunResponse  String?  // AI-generated 1-liner, nullable
  createdAt      DateTime @default(now())

  @@unique([userId, date])
}

model ToolReport {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolType       String   // "bounce_back" | "visualization" | "debrief" | "cue_word"
  summary        String   // 1–2 sentence human-readable summary of what was done
  arjunResponse  String?  // Arjun's closing line shown to athlete
  details        String   @default("{}") // JSON blob of tool-specific fields
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

model WeeklyReport {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart    DateTime // Monday 00:00:00 UTC
  weekEnd      DateTime // Sunday 23:59:59 UTC
  content      String   // Full report text with **bold** section headings
  messageCount Int      // User messages that week (for generation threshold)
  createdAt    DateTime @default(now())

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

model SelfTalkCard {
  id                     String    @id @default(cuid())
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport                  String?
  roleOrPosition         String?
  performanceMoment      String?
  skillContext           String?
  situationCategory      String
  situationText          String?
  oldThought             String
  thoughtIntensityBefore Int?
  confidenceBefore       Int?
  confidenceAfter        Int?
  focusWord              String
  resetWord              String
  powerLine              String
  performanceReminder    String
  arjunNote              String
  safetyFlag             String    @default("safe")
  aiModel                String?
  tags                   Json?
  isActive               Boolean   @default(true)
  isMatchDayCard         Boolean   @default(false)
  matchDayContext        String?
  isArchived             Boolean   @default(false)
  usedCount              Int       @default(0)
  lastUsedAt             DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([userId, isActive, createdAt])
  @@index([userId, isArchived])
}

// Minimal safety-incident log — deliberately stores NO message content or free text.
model SafetyEvent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surface     String   // "chat" | "self_talk" | "body_reset" | "bounce_back"
  triggerType String   // "helpline_response" | "needs_support" | "crisis_keyword" | "intensity_max"
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([userId, createdAt])
}

model BodyResetSession {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode             String    // "quick" | "training"
  feeling          String?
  feelingCustom    String?
  context          String?
  contextCustom    String?
  focusWordUsed    String?
  tensionBefore    Int?
  readinessBefore  Int?
  tensionAfter     Int?
  readinessAfter   Int?
  cyclesCompleted  Int       @default(0)
  durationSeconds  Int       @default(0)
  arjunNote        String?
  arjunTags        Json?
  aiModel          String?
  completedAt      DateTime  @default(now())

  @@index([userId, completedAt])
}
