// MindGame Database Schema
// Run `npm run db:migrate` to apply changes
// Run `npm run db:studio` to open a visual database browser

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  googleId  String   @unique
  email     String   @unique
  name      String
  avatar    String?

  // "free" = limited check-ins/chats per week
  // "premium" = full access (₹299/month)
  tier      String   @default("free")

  // "en" = English, "hi" = Hindi
  language  String   @default("en")

  // Onboarding — collected after first login
  sport           String?          // e.g. "cricket", "badminton"
  experienceLevel String?          // "beginner" | "amateur" | "competitive" | "professional"
  goals           String  @default("[]") // JSON array e.g. '["focus","confidence"]'
  onboardingDone  Boolean @default(false)

  messages  Message[]
  checkIns  CheckIn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CheckIn {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood        Int      // 1–5
  focus       Int      // 1–5
  confidence  Int      // 1–5
  reflection  String?  // optional free-text, max 500 chars
  createdAt   DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())
}
