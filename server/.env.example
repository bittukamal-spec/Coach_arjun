# ─────────────────────────────────────────────────────────────
# MindGame Server — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the .env file to git!
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# Production (Railway PostgreSQL): postgresql://user:pass@host:port/db
# Local dev: install PostgreSQL locally or use Docker
DATABASE_URL="postgresql://user:password@localhost:5432/mindgame"

# ── Anthropic (Claude AI) ─────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model to use for all AI calls. Default: claude-haiku-4-5-20251001
# To switch model: change this one line, redeploy. No code change needed.
# Cheaper options: gpt-4o-mini (OpenAI), gemini-2.0-flash (Google)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── JWT Secret ────────────────────────────────────────────────
# A long random string used to sign login tokens.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_characters

# ── App URLs ─────────────────────────────────────────────────
# Where your React frontend runs
CLIENT_URL=http://localhost:5173

# Port this server listens on
PORT=5000

# ── Email (Resend) ────────────────────────────────────────────
# Get your key at: https://resend.com
# From address must be a verified domain (or use onboarding@resend.dev for testing)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=arjun@yourdomain.com

# ── WhatsApp (Twilio) ─────────────────────────────────────────
# Used for reminders and engagement messages
# Sandbox (free, instant): https://www.twilio.com/try-twilio
# Sandbox number: whatsapp:+14155238886
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── WhatsApp (Meta Cloud API — production) ────────────────────
# After Meta Business verification (3-7 days): business.facebook.com
# Use this INSTEAD of Twilio for production (1000 free messages/month)
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=

# ── Razorpay Payments ────────────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Plan IDs from: https://dashboard.razorpay.com/app/subscriptions/plans
RAZORPAY_PLAN_MONTHLY=
RAZORPAY_PLAN_YEARLY=
# Webhook secret from: https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=

# ── Error Monitoring (Sentry) ─────────────────────────────────
# Free tier: 5000 errors/month — get DSN at: https://sentry.io
SENTRY_DSN=

# ── Analytics (PostHog) ───────────────────────────────────────
# Free tier: 1M events/month — get key at: https://posthog.com
POSTHOG_KEY=
