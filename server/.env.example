# ─────────────────────────────────────────────────────────────
# MindGame Server — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the .env file to git!
# ─────────────────────────────────────────────────────────────

# Database (SQLite file stored locally — no extra setup needed)
DATABASE_URL="file:./dev.db"

# ── Google OAuth ──────────────────────────────────────────────
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create a project → APIs & Services → Credentials
# Step 3: Create OAuth 2.0 Client ID (Web application type)
# Step 4: Add Authorized redirect URI: http://localhost:5000/api/auth/google/callback
# Step 5: Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# The exact callback URL registered in Google Console
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── JWT Secret ────────────────────────────────────────────────
# A long random string used to sign login tokens.
# Generate one at: https://generate-secret.vercel.app/64
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_characters

# ── App URLs ─────────────────────────────────────────────────
# Where your React frontend runs (Vite default port)
CLIENT_URL=http://localhost:5173

# Port this server listens on
PORT=5000
